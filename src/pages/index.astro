---
import Layout from "../layout/layout.astro";
---

<Layout>
  <section>
    <img src="/images/hero.webp" alt="Not Alias_" />
    <div role="contentinfo" class="flex flex-col">
      <article class="mt-12 flex flex-col xl:flex-row xl:justify-between gap-6">
        <p class="text-3xl font-bold xl:text-5xl xl:max-w-[550px]">
          We build brand systems for those raising the standard.
        </p>
        <p
          class="text-[15px] font-light xl:text-xl xl:text-right xl:max-w-[662px] xl:mt-auto"
        >
          We're a strategic branding studio for founders, innovators, and
          leaders who understand that a brand is a living asset. We combine
          business thinking with world-class design to build identities that
          connect, stand out, and endure.
        </p>
      </article>
      <p class="mt-6 text-[15px] font-light xl:text-xl">
        We're rebuilding our home.<br />Our work speaks for itself:
      </p>
      <div class="flex items-center gap-4 my-10 xl:my-20">
        <img
          src="/images/svgs/open-link.svg"
          alt="Ir"
          class="mt-2 w-auto xl:w-[20px]"
        />
        <a
          href="/Not_Alias_Brand_Studio.pdf"
          target="_blank"
          class="flex flex-col"
        >
          <p class="text-xl font-bold xl:text-[28px]">Here’s a taste</p>
          <span class="h-px w-full bg-black"></span>
        </a>
      </div>
    </div>
  </section>
</Layout>
